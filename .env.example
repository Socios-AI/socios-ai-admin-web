# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://axyssxqttfnbtawanasf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cookie config (must match id.sociosai.com so SSO works)
NEXT_PUBLIC_COOKIE_DOMAIN=.sociosai.com
NEXT_PUBLIC_COOKIE_SAMESITE=lax
NEXT_PUBLIC_COOKIE_SECURE=true

# JWT verification (server-only)
SUPABASE_JWT_SECRET=

# Stripe (Plan G.3, server-only)
# Leave empty in dev/CI: stripe-sync.ts returns mock IDs (prod_mock_*, price_mock_*).
# Plug a sk_test_* in local .env.local. Prod gets sk_live_* via secret manager only.
STRIPE_SECRET_KEY=
